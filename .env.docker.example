POSTGRES_DB=kudos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your-bot-token
INTERNAL_API_TOKEN=replace-with-long-random-token
DASHBOARD_SERVICE_TOKEN=replace-with-long-random-token-shared-with-dashboard
USER_SESSION_SIGNING_SECRET=replace-with-min-32-char-secret-shared-with-dashboard
ADMIN_SESSION_SIGNING_SECRET=replace-with-min-32-char-secret
DASHBOARD_ADMIN_SLACK_USER_IDS=U0123456789,U0987654321
SLACK_OIDC_CLIENT_ID=1234567890.1234567890123
SLACK_OIDC_CLIENT_SECRET=replace-with-slack-client-secret
SLACK_OIDC_REDIRECT_URI=http://localhost:3000/auth/slack/callback

DEFAULT_MONTHLY_BALANCE=100
MAX_KUDOS_PER_TRANSACTION=50
ENABLE_DAILY_RECEIVER_CAP=false
