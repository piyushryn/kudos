POSTGRES_DB=kudos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your-bot-token
INTERNAL_API_TOKEN=replace-with-long-random-token

DEFAULT_MONTHLY_BALANCE=100
MAX_KUDOS_PER_TRANSACTION=50
ENABLE_DAILY_RECEIVER_CAP=false
DAILY_RECEIVER_CAP=100
CRON_MONTHLY_RESET=0 2 1 * *
ENABLE_MANUAL_MONTHLY_RESET=false

# Dashboard container (docker-compose `dashboard` service)
DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=changeme
# At least 16 characters; signs the browser session cookie.
DASHBOARD_AUTH_SECRET=replace-with-at-least-16-random-chars
