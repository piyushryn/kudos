# HTTPS with free Let’s Encrypt certs (see ../../certbot/README.md).
# After certbot has created certs under certbot/conf, copy this file:
#   cp nginx/conf.d/default-ssl-letsencrypt.conf.example nginx/conf.d/default.conf
# Ensure docker-compose mounts certbot/www and certbot/conf on nginx.

upstream kudos_api {
    server server:4000;
    keepalive 16;
}

upstream kudos_web {
    server dashboard:3000;
    keepalive 16;
}

server {
    listen 80;
    server_name kudos.piyusharyan.xyz;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type "text/plain";
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name kudos.piyusharyan.xyz;

    ssl_certificate     /etc/letsencrypt/live/kudos.piyusharyan.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/kudos.piyusharyan.xyz/privkey.pem;

    client_max_body_size 1m;

    location ^~ /slack/ {
        proxy_pass http://kudos_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_read_timeout 60s;
    }

    location = /health {
        proxy_pass http://kudos_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }

    location ^~ /api/ {
        proxy_pass http://kudos_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }

    # /admin → Next.js (not Express). See default.conf comment.

    location / {
        proxy_pass http://kudos_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
