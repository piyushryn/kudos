# HTTPS example: copy to default.conf (or merge) once you have certs in ../ssl/
#
#   cp nginx/ssl/fullchain.pem nginx/ssl/privkey.pem   # your Let's Encrypt files
#   cp nginx/conf.d/default-ssl.conf.example nginx/conf.d/default.conf
#   docker compose up -d nginx
#
# Slack slash command URL: https://kudos.piyusharyan.xyz/slack/commands

upstream kudos_api {
    server server:4000;
    keepalive 16;
}

upstream kudos_web {
    server dashboard:3000;
    keepalive 16;
}

server {
    listen 80;
    server_name kudos.piyusharyan.xyz;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name kudos.piyusharyan.xyz;

    ssl_certificate     /etc/nginx/ssl/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/privkey.pem;

    client_max_body_size 1m;

    location ^~ /slack/ {
        proxy_pass http://kudos_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_read_timeout 60s;
    }

    location = /health {
        proxy_pass http://kudos_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }

    location ^~ /api/ {
        proxy_pass http://kudos_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }

    location ^~ /admin/ {
        proxy_pass http://kudos_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }

    location / {
        proxy_pass http://kudos_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
