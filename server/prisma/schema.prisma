generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserCategory {
  id                 String   @id @default(cuid())
  key                String   @unique
  name               String
  monthlyGivingQuota Int?     @map("monthly_giving_quota")
  createdAt          DateTime @default(now()) @map("created_at")
  users              User[]

  @@map("user_categories")
}

enum KudosEntryKind {
  KUDO
  ADMIN_RESET_USER
  ADMIN_RESET_ALL
}

model User {
  id             String       @id @default(cuid())
  slackUserId    String       @unique @map("slack_user_id")
  displayName    String       @map("display_name")
  userCategoryId String       @map("user_category_id")
  userCategory   UserCategory @relation(fields: [userCategoryId], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now()) @map("created_at")
  balances       UserGivingBalance[]
  givenKudos     KudosTransaction[] @relation("GivenKudos")
  receivedKudos  KudosTransaction[] @relation("ReceivedKudos")

  @@index([userCategoryId])
  @@map("users")
}

model UserGivingBalance {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  month           Int
  year            Int
  remainingPoints Int      @map("remaining_points")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([month, year])
  @@map("user_giving_balance")
}

model KudosTransaction {
  id                  String          @id @default(cuid())
  kind                KudosEntryKind  @default(KUDO) @map("kind")
  countsTowardTotals  Boolean         @default(true) @map("counts_toward_totals")
  giverId             String          @map("giver_id")
  receiverId          String          @map("receiver_id")
  points              Int
  message             String
  createdAt           DateTime        @default(now()) @map("created_at")
  month               Int
  year                Int
  channelId           String?         @map("channel_id")
  channelName         String?         @map("channel_name")
  giver               User            @relation("GivenKudos", fields: [giverId], references: [id], onDelete: Restrict)
  receiver            User            @relation("ReceivedKudos", fields: [receiverId], references: [id], onDelete: Restrict)

  @@index([receiverId, month, year])
  @@index([giverId, month, year])
  @@index([createdAt])
  @@index([channelId])
  @@index([kind, countsTowardTotals])
  @@map("kudos_transactions")
}
