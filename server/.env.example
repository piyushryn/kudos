NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017/kudos
# Optional. When set, current-month leaderboard reads are cached for 24h.
# If unset, unreachable, or the connection drops, the server logs and
# continues to serve every request directly from MongoDB.
REDIS_URL=redis://localhost:6379
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_BOT_TOKEN=xoxb-
DEFAULT_MONTHLY_BALANCE=100
MAX_KUDOS_PER_TRANSACTION=50
ENABLE_DAILY_RECEIVER_CAP=false
DAILY_RECEIVER_CAP=100
CRON_MONTHLY_RESET=0 2 1 * *
ENABLE_MANUAL_MONTHLY_RESET=false
SUPER_ADMIN_SLACK_USER_IDS=U0123456789,U0987654321
USER_SESSION_SIGNING_SECRET=replace-with-min-32-char-secret-shared-with-dashboard
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://dashboard.example.com
# Verbose Slack request/response logs (redacts token, response_url, trigger_id). Set false to reduce noise.
SLACK_VERBOSE_LOGGING=true
